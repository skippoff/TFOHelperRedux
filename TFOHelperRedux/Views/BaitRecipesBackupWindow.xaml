<Window x:Class="TFOHelperRedux.Views.BaitRecipesBackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Восстановление из бэкапа"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}">

    <Border BorderBrush="{DynamicResource BorderBrushLight}" 
            BorderThickness="1" 
            CornerRadius="6" 
            Padding="10" 
            Background="{DynamicResource PanelBackground}">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" 
                       Text="Выберите бэкап для восстановления:" 
                       FontSize="14" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,10"/>

            <!-- Список бэкапов -->
            <ListBox Grid.Row="1" 
                     x:Name="BackupsListBox"
                     ItemsSource="{Binding Backups}"
                     SelectedIndex="0"
                     Background="{DynamicResource PanelBackground}"
                     BorderBrush="{DynamicResource BorderBrushLight}"
                     BorderThickness="1"
                     ItemContainerStyle="{StaticResource RoundedCardStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="8,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="Отмена"
                        Height="35"
                        MinWidth="80"
                        Margin="0,0,10,0"
                        Click="CancelButton_Click"/>
                <Button Content="Восстановить"
                        Height="35"
                        Click="RestoreButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
