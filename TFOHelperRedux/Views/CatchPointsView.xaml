<UserControl x:Class="TFOHelperRedux.Views.CatchPointsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🎯 Точки лова"
                   FontSize="18"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

            <!-- имя текущей рыбы -->
            <TextBlock Text="{Binding CurrentFish.Name, FallbackValue='(все)'}"
                   FontSize="16"
                   Foreground="{DynamicResource PrimaryColor}"
                   FontWeight="SemiBold"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"/>
        </StackPanel>

        <ItemsControl Grid.Row="1"
                  ItemsSource="{Binding FilteredPoints}"
                  Margin="0,6,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CatchPointCardStyle}"
                            Margin="3"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- 🗺 Кнопка открытия карты в левом верхнем углу -->
                            <Button Style="{StaticResource SmallIconButton}"
                                    Tag="{StaticResource IconMap}"
                                    Width="36" Height="36"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource ButtonPrimaryBrush}"
                                    Command="{Binding DataContext.OpenMapCmd,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Открыть карту"/>

                            <!-- 📍 Координаты по центру -->
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       Margin="0,8,0,0"
                                       Cursor="Hand"
                                       ToolTip="Нажмите, чтобы скопировать координаты">
                                <TextBlock.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.CopyCoordsCmd,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </TextBlock.InputBindings>
                                <Run Text="X:" Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                                <Run Text="{Binding Coords.X}" Foreground="{DynamicResource TextPrimary}" FontSize="16"/>
                                <Run Text="   Y:" Foreground="{DynamicResource TextSecondary}" FontSize="14"/>
                                <Run Text="{Binding Coords.Y}" Foreground="{DynamicResource TextPrimary}" FontSize="16"/>
                            </TextBlock>

                            <!-- ❌ Крестик (удалить точку) в правом верхнем углу -->
                            <Button Style="{StaticResource SmallIconButton}"
                                    Tag="{StaticResource IconDelete}"
                                    Width="36" Height="36"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource DangerColor}"
                                    Command="{Binding DataContext.DeletePointCmd,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Удалить точку"/>

                            <!-- Контент карточки с отступами для кнопок -->
                            <StackPanel Margin="42,42,42,0">
                                <!-- 💬 Комментарий -->
                                <TextBlock Text="{Binding Comment}"
                                           FontSize="17"
                                           Foreground="{DynamicResource TextPrimary}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,2"/>
                                <!-- Особенности -->
                                <TextBlock TextWrapping="Wrap" Margin="0,2,0,2">
                                    <Run FontSize="17" Foreground="{DynamicResource TextSecondary}" Text="Особенности: "/>
                                    <Run FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="{Binding FeaturesInfo, Converter={StaticResource StripPrefixConverter}, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Время лова -->
                                <TextBlock TextWrapping="Wrap" Margin="0,2,0,2">
                                    <Run FontSize="17" Foreground="{DynamicResource TextSecondary}" Text="Время лова: "/>
                                    <Run FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="{Binding TimeInfo, Converter={StaticResource StripPrefixConverter}, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Тип удилища -->
                                <TextBlock TextWrapping="Wrap" Margin="0,2,0,2">
                                    <Run FontSize="17" Foreground="{DynamicResource TextSecondary}" Text="Тип удилища: "/>
                                    <Run FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="{Binding RodTypeInfo, Converter={StaticResource StripPrefixConverter}, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Глубина -->
                                <TextBlock TextWrapping="Wrap" Margin="0,2,0,4">
                                    <Run FontSize="17" Foreground="{DynamicResource TextSecondary}" Text="Глубина: "/>
                                    <Run FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="{Binding DepthInfo, Converter={StaticResource StripPrefixConverter}, Mode=OneWay}"/>
                                </TextBlock>
                                
                                <!-- Клипса -->
                                <TextBlock TextWrapping="Wrap" Margin="0,2,0,4">
                                    <Run FontSize="17" Foreground="{DynamicResource TextSecondary}" Text="Клипса: "/>
                                    <Run FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="{Binding ClipInfo, Converter={StaticResource StripPrefixConverter}, Mode=OneWay}"/>
                                </TextBlock>

                            </StackPanel>

                            <!-- ✏ Карандаш (редактировать точку) в правом нижнем углу -->
                            <Button Style="{StaticResource SmallIconButton}"
                                    Tag="{StaticResource IconEdit}"
                                    Width="36" Height="36"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,4"
                                    Background="{DynamicResource ButtonEditBrush}"
                                    Command="{Binding DataContext.EditPointCmd,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Редактировать точку"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
