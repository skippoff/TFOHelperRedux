<UserControl x:Class="TFOHelperRedux.Views.FishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TFOHelperRedux.Views"
             xmlns:views="clr-namespace:TFOHelperRedux.Views"
             xmlns:helpers="clr-namespace:TFOHelperRedux.Helpers"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <!--MinHeight="600" MinWidth="900"-->
    <UserControl.Resources>
        <!-- DropShadow для карточек -->
        <DropShadowEffect x:Key="DropShadow" BlurRadius="10" ShadowDepth="2" Opacity="0.25" />
    </UserControl.Resources>
    <Grid x:Name="MainGrid"
        Background="{DynamicResource AppBackground}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Header / Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderBrushLight}"
                BorderThickness="0,0,0,0"
                Padding="0,0">
            <Border Grid.Row="0"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource BorderBrushLight}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- 📁 Импорт / Экспорт / Очистить -->
                    <views:ActionPanel Grid.Column="3" Grid.Row="0" HorizontalAlignment="Right"/>
                    <!-- 🧭 Навигация -->
                    <views:NavigationPanel Grid.Column="0" Grid.Row="0" />
                </Grid>
            </Border>
        </Border>
        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="585"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Прикорм и дипы -->
            <Border Grid.Column="0"
                    Margin="2"
                    Background="{DynamicResource PanelBackground}"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource BorderBrushLight}"
                    BorderThickness="1"
                    Padding="12"
                    Visibility="{Binding NavigationVM.CurrentMode, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter={x:Static helpers:NavigationModes.Baits}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" helpers:ScrollViewerHelper.EnableMouseWheelScroll="True">
                    <StackPanel>
                        <TextBlock Text="ОСНАСТКА"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Margin="4,0,0,8"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <ListBox SelectedValue="{Binding NavigationVM.BaitsSubMode, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource CategoryListBoxItem}"
                                 SelectedValuePath="Tag">
                            <ListBoxItem Content="Прикормки" Tag="Feeds"/>
                            <ListBoxItem Content="Дипы" Tag="Dips"/>
                            <ListBoxItem Content="Наживки" Tag="Lures"/>
                            <ListBoxItem Content="Компоненты прикормки" Tag="FeedComponents"/>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <local:MapsPanel Grid.Column="0"
                             Grid.ColumnSpan="3"
                             Visibility="{Binding NavigationVM.CurrentMode,
                Converter={StaticResource EqualityToVisibilityConverter},
                ConverterParameter={x:Static helpers:NavigationModes.Maps}}"/>
            <local:FishPanel Grid.Column="1"
                             Grid.ColumnSpan="2"
                             Visibility="{Binding NavigationVM.CurrentMode,
                Converter={StaticResource EqualityToVisibilityConverter},
                ConverterParameter={x:Static helpers:NavigationModes.Fish}}"/>
            <local:BaitsPanel Grid.Column="1"
                              Grid.ColumnSpan="2"
                              Visibility="{Binding NavigationVM.CurrentMode,
                Converter={StaticResource EqualityToVisibilityConverter},
                ConverterParameter={x:Static helpers:NavigationModes.Baits}}"/>
            <local:FishDetailsPanel Grid.Column="2">
                <local:FishDetailsPanel.Style>
                    <Style TargetType="local:FishDetailsPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- Показывать панель деталей только при Maps, Fish и FishFeeds -->
                            <DataTrigger Binding="{Binding NavigationVM.CurrentMode}" Value="{x:Static helpers:NavigationModes.Maps}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NavigationVM.CurrentMode}" Value="{x:Static helpers:NavigationModes.Fish}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:FishDetailsPanel.Style>
            </local:FishDetailsPanel>
        </Grid>
    </Grid>
</UserControl>